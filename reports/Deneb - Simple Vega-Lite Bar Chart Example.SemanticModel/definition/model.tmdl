model Model
	culture: en-NZ
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-NZ
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_QueryOrder = ["Source Data","Cities","Average Temperature by Month"]

annotation PBI_ProTooling = ["DevMode"]

ref table Date
ref table Cities
ref table 'Average Temperature by Month'

ref cultureInfo en-NZ

